{
  "name": "cinematic-tech-intro",
  "version": "1.0.0",
  "description": "Cinematic CEO Introduction - Remotion",
  "scripts": {
    "start": "remotion studio",
    "studio": "remotion studio",
    "build": "remotion render src/index.ts CEOIntroduction out/ceo_introduction.mp4",
    "build:tutorial": "remotion render src/index.ts TutorialVideo out/tutorial.mp4",
    "build:agent": "remotion render src/index.ts AgentTutorialVideo out/agent_tutorial.mp4",
    "build:all": "npm run build && npm run build:tutorial && npm run build:agent"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.451",
    "@remotion/player": "^4.0.451",
    "@types/react": "^19.2.14",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "remotion": "^4.0.451",
    "typescript": "^6.0.3"
  }
}
